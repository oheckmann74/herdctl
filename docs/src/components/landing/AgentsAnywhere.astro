---
import webImg from '../../assets/landing/web-herdctl.png';
import slackImg from '../../assets/landing/slack-app.png';
import discordImg from '../../assets/landing/discord-app.png';
---

<div class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:text-center mb-10">
      <h2 class="text-base font-semibold leading-7 text-indigo-600">Talk to Your Agents Anywhere</h2>
      <p class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
        Web, Slack, or Discord — wherever your team already works
      </p>
      <p class="mt-4 text-lg leading-8 text-gray-600">
        Chat with your agents through the built-in Web UI, Slack, or Discord. Send a message from your phone and
        pick up the conversation in your terminal. Every interaction is logged and every session is resumable.
      </p>
    </div>
    <div class="mx-auto max-w-7xl">
      <figure>
        <div class="grid grid-cols-1 sm:grid-cols-3 xl:gap-8 gap-6 items-center">
          <div class="text-center">
            <div class="overflow-hidden rounded-xl shadow-lg ring-1 ring-gray-200">
              <img
                src={webImg.src}
                alt="Web UI showing a conversation with a herdctl agent"
                width={webImg.width}
                height={webImg.height}
                class="w-full h-auto"
              />
            </div>
            <a href="/integrations/web-dashboard/" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">Web Dashboard docs &rarr;</a>
          </div>
          <div class="text-center">
            <div class="overflow-hidden rounded-xl shadow-lg ring-1 ring-gray-200">
              <img
                src={slackImg.src}
                alt="Slack conversation with a herdctl agent"
                width={slackImg.width}
                height={slackImg.height}
                class="w-full h-auto"
              />
            </div>
            <a href="/guides/slack-quick-start/" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">Slack quick start &rarr;</a>
          </div>
          <div class="text-center">
            <div class="overflow-hidden rounded-xl shadow-lg ring-1 ring-gray-200">
              <img
                src={discordImg.src}
                alt="Discord conversation with a herdctl agent"
                width={discordImg.width}
                height={discordImg.height}
                class="w-full h-auto"
              />
            </div>
            <a href="/guides/discord-quick-start/" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">Discord quick start &rarr;</a>
          </div>
        </div>
        <figcaption class="mt-3 text-sm text-gray-500 text-center italic">The same agent, accessible from Web, Slack, and Discord</figcaption>
      </figure>
    </div>
    <div class="mt-8 flex justify-center items-start gap-4 flex-wrap">
      <!-- Slack Button -->
      <a
        href="/guides/slack-quick-start/"
        class="no-underline inline-flex items-center gap-1.5 rounded-md bg-[#4A154B] px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-[#3b1139]"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zm1.271 0a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zm0 1.271a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zm10.122 2.521a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zm-1.268 0a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zm-2.523 10.122a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zm0-1.268a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z" />
        </svg>
        <span>Get started with Slack</span>
      </a>
      <!-- Web UI Button (center, featured) -->
      <div class="flex flex-col items-center">
        <a
          href="/integrations/web-dashboard/"
          class="no-underline inline-flex items-center gap-1.5 rounded-md bg-indigo-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FFD700" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6" />
            <path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18" />
            <path d="M4 22h16" />
            <path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20 7 22" />
            <path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20 17 22" />
            <path d="M18 2H6v7a6 6 0 0 0 12 0V2Z" />
          </svg>
          <span>Get started with Web UI</span>
        </a>
        <span class="mt-1.5 inline-block rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-semibold text-amber-800">Fastest setup</span>
      </div>
      <!-- Discord Button -->
      <a
        href="/guides/discord-quick-start/"
        class="no-underline inline-flex items-center gap-1.5 rounded-md bg-[#5865F2] px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-[#4752C4]"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
        </svg>
        <span>Get started with Discord</span>
      </a>
    </div>
  </div>
</div>
