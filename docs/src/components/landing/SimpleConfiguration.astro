      <!-- FleetConfigExample -->
      <div class="rounded-xl bg-gray-900 p-6 shadow-xl ring-1 ring-white/10">
        <div class="flex items-center gap-2 mb-4">
          <div class="h-3 w-3 rounded-full bg-red-500"></div>
          <div class="h-3 w-3 rounded-full bg-yellow-500"></div>
          <div class="h-3 w-3 rounded-full bg-green-500"></div>
          <span class="ml-2 text-sm text-gray-400">herdctl.yaml</span>
        </div>
        <pre class="text-sm text-gray-300 overflow-x-auto"><code><span class="text-indigo-400">version</span><span class="text-gray-500">:</span> 1

<span class="text-indigo-400">fleet</span><span class="text-gray-500">:</span>
  <span class="text-indigo-400">name</span><span class="text-gray-500">:</span> my-dev-fleet
  <span class="text-indigo-400">description</span><span class="text-gray-500">:</span> Development agents

<span class="text-indigo-400">defaults</span><span class="text-gray-500">:</span>
  <span class="text-indigo-400">model</span><span class="text-gray-500">:</span> sonnet
  <span class="text-indigo-400">max_turns</span><span class="text-gray-500">:</span> 50

<span class="text-indigo-400">agents</span><span class="text-gray-500">:</span>
  - <span class="text-indigo-400">path</span><span class="text-gray-500">:</span> ./agents/pr-reviewer
  - <span class="text-indigo-400">path</span><span class="text-gray-500">:</span> ./agents/docs-writer
  - <span class="text-indigo-400">path</span><span class="text-gray-500">:</span> ./agents/monitor
    <span class="text-indigo-400">overrides</span><span class="text-gray-500">:</span>
      <span class="text-indigo-400">docker</span><span class="text-gray-500">:</span>
        <span class="text-indigo-400">enabled</span><span class="text-gray-500">:</span> <span class="text-green-400">true</span></code></pre>
      </div>
