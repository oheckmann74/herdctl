<div class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:text-center mb-12">
      <h2 class="text-base font-semibold leading-7 text-indigo-600">Simple Configuration</h2>
      <p class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
        Your fleet in a few YAML files
      </p>
      <p class="mt-4 text-lg leading-8 text-gray-600">
        One herdctl.yaml defines your fleet. Each agent gets its own directory with a herdctl-agent.yaml. Secrets
        live in .env.
      </p>
    </div>
    <div class="mx-auto max-w-5xl grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- FileSystemView -->
      <div class="rounded-xl bg-gray-900 p-6 shadow-xl ring-1 ring-white/10">
        <div class="flex items-center gap-2 mb-4">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-yellow-400" aria-hidden="true">
            <path d="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z" />
          </svg>
          <span class="text-sm text-gray-400">Fleet Directory Structure</span>
        </div>
        <div class="text-sm font-mono">
          <div class="text-gray-300">
            <span class="text-yellow-400">my-fleet/</span>
          </div>
          <div class="text-gray-300 pl-4">
            <span class="text-indigo-400">&boxvr;&horbar; </span>
            <a href="/configuration/fleet-config/" class="text-indigo-400 hover:text-indigo-300">herdctl.yaml</a>
            <span class="text-gray-500 ml-4"># Fleet config</span>
          </div>
          <div class="text-gray-300 pl-4">
            <span class="text-indigo-400">&boxvr;&horbar; </span>
