            <span class="text-gray-500 ml-4"># API keys &amp; secrets</span>
          </div>
          <div class="text-gray-300 pl-4">
            <span class="text-indigo-400">&boxvr;&horbar; </span>
            <span class="text-yellow-400">agents/</span>
          </div>
          <div class="text-gray-300 pl-8">
            <span class="text-indigo-400">&boxvr;&horbar; </span>
            <span class="text-yellow-400">pr-reviewer/</span>
          </div>
          <div class="text-gray-300 pl-12">
            <span class="text-indigo-400">&boxur;&horbar; </span>
            <a href="/configuration/agent-config/" class="text-indigo-400 hover:text-indigo-300">herdctl-agent.yaml</a>
          </div>
          <div class="text-gray-300 pl-8">
            <span class="text-indigo-400">&boxvr;&horbar; </span>
