---
import logoSrc from '../../assets/landing/herdctl-logo-small.svg';
---

<div class="relative isolate overflow-hidden bg-gradient-to-b from-indigo-100/20 pt-14">
  <div class="mx-auto max-w-7xl px-6 py-16 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-2xl lg:mx-0 lg:grid lg:max-w-none lg:grid-cols-2 lg:gap-x-16 lg:gap-y-6 xl:grid-cols-1 xl:grid-rows-1 xl:gap-x-8">
      <div class="lg:col-span-2 xl:col-auto">
        <div class="flex items-center gap-4 mb-6">
          <img
            src={logoSrc.src}
            alt="herdctl logo"
            width="64"
            height="64"
            class="rounded-xl"
          />
          <h1 class="m-0 p-0 text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">herdctl</h1>
        </div>
        <p class="text-xl font-semibold text-indigo-600 mb-4">Let Claude Code invoke itself.</p>
        <p class="mt-4 text-lg leading-8 text-gray-600">
          Run agents on schedules, chat with them on Discord or Slack, and resume any session in your terminal.
          herdctl is an open-source orchestration layer that turns Claude Code into autonomous agents.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4 flex-wrap">
          <!-- GitHub Button -->
          <a
            href="https://github.com/edspencer/herdctl"
            class="no-underline inline-flex items-center gap-1.5 rounded-md bg-white px-3.5 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50"
          >
            <svg width="20" height="20" viewBox="0 0 98 96" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.141-22.243-5.378-22.243-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z"
                fill="#24292f"
              />
            </svg>
            <span>View on GitHub</span>
          </a>

          <!-- Blog Button -->
          <a
            href="https://edspencer.net/herdctl"
            target="_blank"
            rel="noopener noreferrer"
            class="no-underline inline-flex items-center gap-1.5 rounded-md bg-indigo-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
            </svg>
            <span>Read the Blog</span>
          </a>

          <!-- Discord Button -->
          <a
            href="https://discord.gg/d2eXZKtNrh"
            target="_blank"
            rel="noopener noreferrer"
            class="no-underline inline-flex items-center gap-1.5 rounded-md bg-[#5865F2] px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-[#4752C4]"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z" />
            </svg>
            <span>Join Discord</span>
          </a>

          <!-- YouTube Button -->
          <a
            href="https://www.youtube.com/watch?v=b3MRrpHLu8M"
            target="_blank"
            rel="noopener noreferrer"
            class="no-underline inline-flex items-center gap-1.5 rounded-md bg-[#FF0000] px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-[#CC0000]"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
            </svg>
            <span>Watch Video</span>
          </a>
        </div>
      </div>
      <div class="mt-10 lg:mt-0 xl:col-end-1 xl:row-start-1">
        <!-- QuickStartCode -->
        <div class="rounded-xl bg-gray-900 p-6 shadow-xl ring-1 ring-white/10">
          <div class="flex items-center gap-2 mb-4" style="margin-top: 0;">
            <span class="inline-block h-3 w-3 rounded-full bg-red-500" style="margin: 0;"></span>
            <span class="inline-block h-3 w-3 rounded-full bg-yellow-500" style="margin: 0;"></span>
            <span class="inline-block h-3 w-3 rounded-full bg-green-500" style="margin: 0;"></span>
            <span class="ml-2 text-sm text-gray-400" style="margin: 0;">Quick Start</span>
          </div>
          <pre class="text-sm text-gray-300 overflow-x-auto"><code><span class="text-gray-500"># Install herdctl globally</span>
<span class="text-green-400">npm</span> install -g herdctl

<span class="text-gray-500"># Initialize your fleet</span>
<span class="text-green-400">herdctl</span> init

<span class="text-gray-500"># Start your fleet</span>
<span class="text-green-400">herdctl</span> start</code></pre>
        </div>
      </div>
    </div>
  </div>
</div>
