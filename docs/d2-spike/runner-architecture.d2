# Runner Architecture - herdctl execution engine
# Shows job creation, session validation, runtime factory, SDK adapter, message processing, and error handling

direction: down

# Entry point
runner-options: {
  label: "RunnerOptions\nagent config + prompt"
  style.fill: "#94a3b8"
  style.stroke: "#64748b"
  style.font-color: "#0f172a"
  style.border-radius: 8
  style.font-size: 14
  style.shadow: true
}

# Job Executor - main orchestration
job-executor: {
  label: "JobExecutor\norchestrates full lifecycle"
  style.fill: "#326CE5"
  style.stroke: "#2857b8"
  style.font-color: "#ffffff"
  style.border-radius: 10
  style.font-size: 16
  style.shadow: true
  style.bold: true
}

# Job creation and session validation
job-record: {
  label: "Create Job Record\nstatus → running"
  style.fill: "#93c5fd"
  style.stroke: "#60a5fa"
  style.font-color: "#1e293b"
  style.border-radius: 8
  style.font-size: 14
  style.shadow: true
}

session-validation: {
  label: "Session Validation\nresume / fork / fresh"
  style.fill: "#38bdf8"
  style.stroke: "#0ea5e9"
  style.font-color: "#0c4a6e"
  style.border-radius: 8
  style.font-size: 14
  style.shadow: true
}

# Runtime Layer container
runtime-layer: {
  label: "Runtime Layer"
  style.fill: "#1e3a5f"
  style.stroke: "#142842"
  style.stroke-width: 2
  style.font-color: "#ffffff"
  style.border-radius: 12
  style.shadow: true
  style.font-size: 18

  grid-columns: 2
  grid-gap: 12

  runtime-factory: {
    label: "RuntimeFactory"
    style.fill: "#c4b5fd"
    style.stroke: "#a78bfa"
    style.font-color: "#2e1065"
    style.border-radius: 6
    style.font-size: 13
  }

  sdk-runtime: {
    label: "SDKRuntime\nquery() via Agent SDK"
    style.fill: "#6ee7b7"
    style.stroke: "#34d399"
    style.font-color: "#064e3b"
    style.border-radius: 6
    style.font-size: 13
  }

  cli-runtime: {
    label: "CLIRuntime\nspawns claude CLI"
    style.fill: "#a3e635"
    style.stroke: "#84cc16"
    style.font-color: "#1a2e05"
    style.border-radius: 6
    style.font-size: 13
  }

  container-runner: {
    label: "ContainerRunner\nDocker decorator"
    style.fill: "#fb923c"
    style.stroke: "#f97316"
    style.font-color: "#431407"
    style.border-radius: 6
    style.font-size: 13
  }
}

# SDK Adapter
sdk-adapter: {
  label: "SDK Adapter\ntoSDKOptions()\nconfig → SDK query options"
  style.fill: "#fdba74"
  style.stroke: "#f59e0b"
  style.font-color: "#451a03"
  style.border-radius: 8
  style.font-size: 14
  style.shadow: true
}

# Claude Agent SDK - external service
claude-sdk: {
  label: "Claude Agent SDK\nquery() → AsyncIterable"
  style.fill: "#fbbf24"
  style.stroke: "#d97706"
  style.font-color: "#451a03"
  style.border-radius: 8
  style.font-size: 14
  style.shadow: true
  style.bold: true
}

# Message Processing container
message-processing: {
  label: "Message Processing"
  style.fill: "#2a9d8f"
  style.stroke: "#21867a"
  style.stroke-width: 2
  style.font-color: "#ffffff"
  style.border-radius: 12
  style.shadow: true
  style.font-size: 18

  grid-columns: 1
  grid-gap: 10

  message-processor: {
    label: "Message Processor\nprocessSDKMessage()\nSDK msg → JobOutput"
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.font-color: "#1e293b"
    style.border-radius: 6
    style.font-size: 13
  }

  terminal-detection: {
    label: "Terminal Detection\nisTerminalMessage()\nresult / error / end"
    style.fill: "#22d3ee"
    style.stroke: "#06b6d4"
    style.font-color: "#083344"
    style.border-radius: 6
    style.font-size: 13
  }
}

# Output storage
jsonl-output: {
  label: ".herdctl/jobs/ID.jsonl\nappend per message"
  style.fill: "#6ee7b7"
  style.stroke: "#34d399"
  style.font-color: "#064e3b"
  style.border-radius: 8
  style.font-size: 14
  style.shadow: true
}

# Error handling
error-handler: {
  label: "Error Handler\nclassifyError()\nwrapError()"
  style.fill: "#f87171"
  style.stroke: "#ef4444"
  style.font-color: "#ffffff"
  style.border-radius: 8
  style.font-size: 14
  style.shadow: true
}

# Final result
runner-result: {
  label: "RunnerResult\nsuccess · jobId · sessionId\nsummary · errorDetails"
  style.fill: "#326CE5"
  style.stroke: "#2857b8"
  style.font-color: "#ffffff"
  style.border-radius: 10
  style.font-size: 14
  style.shadow: true
  style.bold: true
}

# Main flow connections
runner-options -> job-executor
job-executor -> job-record
job-record -> session-validation
session-validation -> runtime-layer.runtime-factory

# Runtime factory to runtimes
runtime-layer.runtime-factory -> runtime-layer.sdk-runtime: sdk {
  style.stroke: "#a78bfa"
}
runtime-layer.runtime-factory -> runtime-layer.cli-runtime: cli {
  style.stroke: "#a78bfa"
}

# Docker decorator connections (dashed)
runtime-layer.container-runner -> runtime-layer.sdk-runtime: docker enabled {
  style.stroke: "#f97316"
  style.stroke-dash: 4
}
runtime-layer.container-runner -> runtime-layer.cli-runtime {
  style.stroke: "#f97316"
  style.stroke-dash: 4
}

# SDK runtime to adapter to Claude
runtime-layer.sdk-runtime -> sdk-adapter
sdk-adapter -> claude-sdk

# Claude SDK to message processing
claude-sdk -> message-processing.message-processor: "AsyncIterable\nSDKMessage stream" {
  style.stroke: "#d97706"
  style.stroke-width: 2
}

# CLI runtime to message processor
runtime-layer.cli-runtime -> message-processing.message-processor: "session file watcher\nSDKMessage stream" {
  style.stroke: "#84cc16"
}

# Message processing internal flow
message-processing.message-processor -> jsonl-output
message-processing.message-processor -> message-processing.terminal-detection

# Terminal detection loop
message-processing.terminal-detection -> message-processing.message-processor: not terminal {
  style.stroke: "#06b6d4"
  style.stroke-dash: 3
}

# Terminal to error handler
message-processing.terminal-detection -> error-handler: terminal {
  style.stroke: "#ef4444"
}

# Final outputs
error-handler -> runner-result
jsonl-output -> runner-result
