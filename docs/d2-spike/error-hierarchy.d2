  label: "RunnerError"
  style.fill: "#326CE5"
  style.stroke: "#2857b8"
  style.stroke-width: 2
  style.font-color: "#ffffff"
  style.border-radius: 12
  style.shadow: true
  style.font-size: 18

  grid-columns: 1
  grid-gap: 8

  SDKInitializationError {
    style.fill: "#22d3ee"
    style.stroke: "#06b6d4"
    style.font-color: "#083344"
    style.border-radius: 6
    style.font-size: 12
  }
  SDKStreamingError {
    style.fill: "#a3e635"
    style.stroke: "#84cc16"
    style.font-color: "#1a2e05"
    style.border-radius: 6
    style.font-size: 12
  }
  MalformedResponseError {
    style.fill: "#fb923c"
    style.stroke: "#f97316"
    style.font-color: "#431407"
    style.border-radius: 6
    style.font-size: 12
  }
}

