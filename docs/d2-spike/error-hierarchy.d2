# Error Hierarchy Diagram
# Shows the complete error type hierarchy for @herdctl/core

direction: right

# Container styling
FleetManagerError: {
  label: "FleetManagerError"
  style.fill: "#1e3a5f"
  style.stroke: "#142842"
  style.stroke-width: 2
  style.font-color: "#ffffff"
  style.border-radius: 12
  style.shadow: true
  style.font-size: 18

  grid-columns: 2
  grid-gap: 8

  ConfigurationError {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.font-color: "#1e293b"
    style.border-radius: 6
    style.font-size: 12
  }
  AgentNotFoundError {
    style.fill: "#94a3b8"
    style.stroke: "#64748b"
    style.font-color: "#0f172a"
    style.border-radius: 6
    style.font-size: 12
  }
  JobNotFoundError {
    style.fill: "#93c5fd"
    style.stroke: "#60a5fa"
    style.font-color: "#1e293b"
    style.border-radius: 6
    style.font-size: 12
  }
  ScheduleNotFoundError {
    style.fill: "#38bdf8"
    style.stroke: "#0ea5e9"
    style.font-color: "#0c4a6e"
    style.border-radius: 6
    style.font-size: 12
  }
  InvalidStateError {
    style.fill: "#fdba74"
    style.stroke: "#f59e0b"
    style.font-color: "#451a03"
    style.border-radius: 6
    style.font-size: 12
  }
  ConcurrencyLimitError {
    style.fill: "#fbbf24"
    style.stroke: "#d97706"
    style.font-color: "#451a03"
    style.border-radius: 6
    style.font-size: 12
  }
  JobCancelError {
    style.fill: "#f87171"
    style.stroke: "#ef4444"
    style.font-color: "#ffffff"
    style.border-radius: 6
    style.font-size: 12
  }
  JobForkError {
    style.fill: "#fda4af"
    style.stroke: "#fb7185"
    style.font-color: "#4c0519"
    style.border-radius: 6
    style.font-size: 12
  }
  FleetManagerShutdownError {
    style.fill: "#c4b5fd"
    style.stroke: "#a78bfa"
    style.font-color: "#2e1065"
    style.border-radius: 6
    style.font-size: 12
  }
  FleetManagerStateDirError {
    style.fill: "#6ee7b7"
    style.stroke: "#34d399"
    style.font-color: "#064e3b"
    style.border-radius: 6
    style.font-size: 12
  }
}

